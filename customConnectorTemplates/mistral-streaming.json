{
  "name": "Mistral — Streaming",
  "description": "Connect to the Mistral API with streaming enabled. Tokens appear in real-time as the model generates them.",
  "requiresStreaming": true,
  "fields": [
    {
      "key": "api_key",
      "label": "Mistral API Key",
      "type": "text",
      "placeholder": "your-mistral-api-key",
      "inputType": "password"
    },
    {
      "key": "model",
      "label": "Model",
      "type": "select",
      "options": [
        { "value": "mistral-small-latest", "label": "Mistral Small" },
        { "value": "mistral-medium-latest", "label": "Mistral Medium" },
        { "value": "mistral-large-latest", "label": "Mistral Large" }
      ],
      "default": "mistral-small-latest"
    }
  ],
  "connector": {
    "version": "1",
    "request": {
      "url": "https://api.mistral.ai/v1/chat/completions",
      "method": "POST",
      "auth": {
        "type": "bearer",
        "token": "{{api_key}}"
      },
      "headers": {
        "Content-Type": "application/json",
        "Accept": "text/event-stream"
      },
      "timeoutMs": 30000,
      "stream": true
    },
    "aiPayload": {
      "model": "{{model}}",
      "temperature": 0.7,
      "max_tokens": 1024,
      "stream": true
    },
    "history": {
      "mode": "array",
      "extractSystem": false
    },
    "response": {
      "resultPath": "$.choices[0].message.content",
      "stream": {
        "linePrefix": "data:",
        "doneSignal": "[DONE]",
        "extractors": [
          { "tokenPath": "$.choices[0].delta.content" }
        ]
      }
    }
  }
}
