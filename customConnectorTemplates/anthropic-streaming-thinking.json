{
  "name": "Anthropic Claude — Streaming + Extended Thinking",
  "description": "Claude models with streaming and extended thinking enabled. A collapsible 'Thinking' block appears above the response.",
  "requiresStreaming": true,
  "fields": [
    {
      "key": "api_key",
      "label": "Anthropic API Key",
      "type": "text",
      "placeholder": "sk-ant-api03-...",
      "inputType": "password"
    },
    {
      "key": "model",
      "label": "Model",
      "type": "select",
      "options": [
        { "value": "claude-opus-4-20250514", "label": "Claude Opus 4" },
        { "value": "claude-sonnet-4-20250514", "label": "Claude Sonnet 4" },
        { "value": "claude-haiku-3-5-20241022", "label": "Claude 3.5 Haiku" }
      ],
      "default": "claude-sonnet-4-20250514"
    },
    {
      "key": "budget_tokens",
      "label": "Thinking Budget (tokens)",
      "type": "select",
      "options": [
        { "value": "5000", "label": "5,000 — light reasoning" },
        { "value": "10000", "label": "10,000 — moderate reasoning" },
        { "value": "16000", "label": "16,000 — deep reasoning" }
      ],
      "default": "10000"
    }
  ],
  "connector": {
    "version": "1",
    "request": {
      "url": "https://api.anthropic.com/v1/messages",
      "method": "POST",
      "auth": {
        "type": "custom",
        "header": "x-api-key",
        "value": "{{api_key}}"
      },
      "headers": {
        "Content-Type": "application/json",
        "anthropic-version": "2023-06-01",
        "Accept": "text/event-stream"
      },
      "timeoutMs": 60000,
      "stream": true
    },
    "aiPayload": {
      "model": "{{model}}",
      "system": "{{systemPrompt}}",
      "max_tokens": 16000,
      "thinking": {
        "type": "enabled",
        "budget_tokens": "{{budget_tokens:int}}"
      },
      "stream": true
    },
    "history": {
      "mode": "array",
      "extractSystem": true,
      "systemParam": "system"
    },
    "response": {
      "resultPath": "$.content[0].text",
      "reasoningPath": "$.content[0].thinking",
      "stream": {
        "linePrefix": "data:",
        "doneSignal": "[DONE]",
        "extractors": [
          {
            "filter": { "$.type": "content_block_delta", "$.delta.type": "text_delta" },
            "tokenPath": "$.delta.text"
          }
        ],
        "reasoningExtractors": [
          {
            "filter": { "$.type": "content_block_delta", "$.delta.type": "thinking_delta" },
            "tokenPath": "$.delta.thinking"
          }
        ]
      }
    }
  }
}
